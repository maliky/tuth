{
  "name": "tusis-js-tools",
  "private": true,
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "typescript": "^5.7.2"
  },
  "scripts": {
    "build:ts": "tsc -p tsconfig.json",
    "check:ts": "npm run format:check:ts && npm run lint:ts && npm run typecheck:ts",
    "lint:ts": "eslint \"app/**/static/**/*.ts\"",
    "typecheck:ts": "tsc -p tsconfig.json --noEmit",
    "format:check:ts": "prettier --check \"app/**/static/**/*.ts\"",
    "format:ts": "prettier --write \"app/**/static/**/*.ts\""
  }
}
