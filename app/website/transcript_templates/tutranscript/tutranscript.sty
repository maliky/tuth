% Transcript metadata defaults. Generated Org files renew these macros.
\newcommand{\TUTranscriptLogoFile}{logo120pi.png}
\newcommand{\TUTranscriptInstitutionName}{William V.S. Tubman University}
\newcommand{\TUTranscriptAddressOne}{Tubman Town, East Harper}
\newcommand{\TUTranscriptAddressTwo}{Maryland County}
\newcommand{\TUTranscriptCountry}{Republic of Liberia}
\newcommand{\TUTranscriptWebsite}{www.Tubmanu.edu.lr}
\newcommand{\TUTranscriptRegistrarEmail}{registrar@tubmanu.edu.lr}
\newcommand{\TUTranscriptDocumentTitle}{Official Student Transcript}
\newcommand{\TUTranscriptDraftLabel}{DRAFT TEMPLATE - NOT AN OFFICIAL RECORD}
\newcommand{\TUTranscriptStudentName}{Student Name}
\newcommand{\TUTranscriptStudentAddressOne}{Address line 1}
\newcommand{\TUTranscriptStudentAddressTwo}{Address line 2}
\newcommand{\TUTranscriptStudentID}{TU-00000}
\newcommand{\TUTranscriptDOB}{DOB}
\newcommand{\TUTranscriptCollege}{College}
\newcommand{\TUTranscriptProgramCode}{Program Code}
\newcommand{\TUTranscriptProgramName}{Program Name}
\newcommand{\TUTranscriptMajorProgram}{Major Program}
\newcommand{\TUTranscriptEnrollmentDate}{Enrollment Date}
\newcommand{\TUTranscriptCompletionDate}{Program Completion Date}
\newcommand{\TUTranscriptGraduationDate}{Graduation Date}
\newcommand{\TUTranscriptProgramTotalAttempted}{0.00}
\newcommand{\TUTranscriptProgramTotalEarned}{0.00}
\newcommand{\TUTranscriptProgramTotalGPA}{0.00}
\newcommand{\TUTranscriptCumulativeTotalAttempted}{0.00}
\newcommand{\TUTranscriptCumulativeTotalEarned}{0.00}
\newcommand{\TUTranscriptCumulativeTotalQuality}{0.00}
\newcommand{\TUTranscriptCumulativeTotalGPA}{0.00}
\newcommand{\TUTranscriptPrintedDate}{\today}
\newcommand{\TUTranscriptPrintedDateShort}{\today}
\newcommand{\TUTranscriptGradeLegend}{A = 90-100; B = 80-89; C = 70-79; D = 60-69; F = 0-59}
\newcommand{\TUTranscriptNoticeFinal}{This is a true copy of the records for the above named student. When inscribed with the seal of William V.S. Tubman University Registrar's Office, this constitutes an Official Transcript.}
\newcommand{\TUTranscriptRegistrarTitle}{REGISTRAR}
\newcommand{\TUTranscriptDetailRows}{}

\newcommand{\TUTranscriptLogo}{%
  \IfFileExists{\TUTranscriptLogoFile}{\includegraphics[height=1.45cm]{\TUTranscriptLogoFile}}{}%
}

\newcommand{\TUTranscriptHeaderBlock}{%
  \begin{minipage}[c]{0.18\textwidth}\raggedright
    \TUTranscriptLogo
  \end{minipage}%
  \begin{minipage}[c]{0.48\textwidth}\centering\scriptsize
    \textbf{\TUTranscriptInstitutionName}\\[-1pt]
    \TUTranscriptAddressOne\\[-1pt]
    \TUTranscriptAddressTwo, \TUTranscriptCountry\\[-1pt]
    \TUTranscriptWebsite{} · \TUTranscriptRegistrarEmail\\[1ex]
    \textbf{\TUTranscriptDocumentTitle}\\[-1pt]
    \ifdefempty{\TUTranscriptDraftLabel}{}{\textcolor{red!70!black}{\bfseries\TUTranscriptDraftLabel}}%
  \end{minipage}%
  \begin{minipage}[c]{0.34\textwidth}\raggedleft\scriptsize
    \textbf{\TUTranscriptStudentName}\\[-1pt]
    \TUTranscriptStudentAddressOne\\[-1pt]
    \ifdefempty{\TUTranscriptStudentAddressTwo}{}{\TUTranscriptStudentAddressTwo\\[-1pt]}
    ID \textbf{\TUTranscriptStudentID}\\[-1pt]
    DOB \TUTranscriptDOB
  \end{minipage}%
}

\fancyhead[C]{\TUTranscriptHeaderBlock}
\fancyfoot[C]{\scriptsize Page \thepage{} of \pageref{LastPage}}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

\newcommand{\TUPrintTranscriptSummary}{%
  {\bfseries Transcript Summary}\par
  \vspace{2pt}
  \begin{minipage}[t]{0.57\textwidth}
    \begin{tabularx}{\linewidth}{@{}p{4.15cm}X@{}}
      Program Code: & \TUTranscriptProgramCode\\
      College: & \TUTranscriptCollege\\
      Enrollment Date: & \TUTranscriptEnrollmentDate\\
      Program Completion Date: & \TUTranscriptCompletionDate\\
      Graduation Date: & \TUTranscriptGraduationDate\\
      Major Program: & \TUTranscriptMajorProgram\\
    \end{tabularx}
  \end{minipage}\hfill
  \begin{minipage}[t]{0.36\textwidth}\raggedleft
    \begin{tabularx}{\linewidth}{@{}X>{\RaggedLeft\arraybackslash}p{1.55cm}>{\RaggedLeft\arraybackslash}p{1.45cm}>{\RaggedLeft\arraybackslash}p{0.8cm}@{\hspace{0.35cm}}}
         & Attempted Credit & Earned Credit & GPA\\
      Program Totals: & \TUTranscriptProgramTotalAttempted & \TUTranscriptProgramTotalEarned & \TUTranscriptProgramTotalGPA\\
      Cumulative Totals: & \TUTranscriptCumulativeTotalAttempted & \TUTranscriptCumulativeTotalEarned & \TUTranscriptCumulativeTotalGPA\\
    \end{tabularx}
  \end{minipage}\par
  \vspace{0.4\baselineskip}
}

\newcolumntype{L}[1]{>{\RaggedRight\arraybackslash}p{#1}}
\newcolumntype{R}[1]{>{\RaggedLeft\arraybackslash}p{#1}}
\newcolumntype{C}[1]{>{\Centering\arraybackslash}p{#1}}

\newenvironment{TUTranscriptDetails}{%
  \scriptsize
  \begin{longtable}{@{}L{7.2cm}C{1.35cm}C{1.35cm}C{0.9cm}R{1.15cm}R{1.15cm}R{1.3cm}@{}}
  \multicolumn{1}{@{}l}{\textbf{Transcript Detail}} & \textbf{Start Date} & \textbf{End Date} & \textbf{Final Grade} & \multicolumn{1}{r}{\textbf{Attmpt Credit}} & \multicolumn{1}{r}{\textbf{Earned Credit}} & \multicolumn{1}{r@{}}{\textbf{Quality Points}}\\
  \midrule
  \endfirsthead
  \multicolumn{1}{@{}l}{\textbf{Transcript Detail}} & \textbf{Start Date} & \textbf{End Date} & \textbf{Final Grade} & \multicolumn{1}{r}{\textbf{Attmpt Credit}} & \multicolumn{1}{r}{\textbf{Earned Credit}} & \multicolumn{1}{r@{}}{\textbf{Quality Points}}\\
  \midrule
  \endhead
}{%
  \end{longtable}
}

\newcommand{\TUTranscriptProgramRow}[2]{%
  \multicolumn{7}{@{}l@{}}{\textbf{#1 Program: #2}}\\[-1pt]
}

\newcommand{\TUTranscriptTermHeader}[3]{%
  \addlinespace[3pt]
  \multicolumn{7}{@{}l@{}}{\textbf{#1}\hfill #2 -- #3}\\
}

\newcommand{\TUTranscriptCourse}[8]{%
  \textbf{#1}\quad #2 & #3 & #4 & #5 & #6 & #7 & #8\\
}

\newcommand{\TUTranscriptTotals}[5]{%
  \multicolumn{4}{@{}l}{\hspace{1.0cm}\textbf{#1}\quad GPA=#2} & \textbf{#3} & \textbf{#4} & \textbf{#5}\\
}

\newcommand{\TUTranscriptEmptyRow}[1]{%
  \multicolumn{7}{@{}l@{}}{#1}\\
}

\newcommand{\TUPrintTranscriptDetails}{%
  \begin{TUTranscriptDetails}
  \TUTranscriptDetailRows
  \end{TUTranscriptDetails}
}

\newcommand{\TUPrintTranscriptConclusion}{%
  \vspace{0.4\baselineskip}
  {\scriptsize\textbf{Transcript Grade Legend:} \TUTranscriptGradeLegend}\par
  \vspace{1.1\baselineskip}
  {\centering\bfseries ***CONCLUSION OF TRANSCRIPT***\par}
  \vspace{1.3\baselineskip}
  \begin{tabularx}{\textwidth}{@{}Xr@{}}
    \scriptsize \TUTranscriptNoticeFinal & \\
    & \\
    & \rule{4.2cm}{0.4pt}\\[-2pt]
    & {\scriptsize \TUTranscriptRegistrarTitle\hspace{1.5cm}Date}\\
  \end{tabularx}
}

\newcommand{\TUPrintTranscript}{%
  \TUPrintTranscriptSummary
  \TUPrintTranscriptDetails
  \TUPrintTranscriptConclusion
}

\endinput
