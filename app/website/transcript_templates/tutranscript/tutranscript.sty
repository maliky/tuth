\newcommand{\TUPrintTranscriptBackMatter}{%
  \clearpage
  {\centering\bfseries Transcript Back Matter\par}
  \vspace{0.6\baselineskip}
  {\scriptsize \TUTranscriptGradePolicyIntro\par}
  \vspace{0.7\baselineskip}
  {\scriptsize\bfseries Grade Letters and Credit Points\par}
  \begin{tabularx}{\textwidth}{@{}p{2.8cm}p{2.4cm}Xr@{}}
    \toprule
    Numerical Value & Letter Grade & Meaning & Index Number\\
    \midrule
    90--100 & A & Excellent & 4.0\\
    80--89 & B & Good & 3.0\\
    70--79 & C & Average & 2.0\\
    60--69 & D & Poor & 1.0\\
    Below 60 & F & Failure & 0.0\\
    \bottomrule
  \end{tabularx}
  \vspace{0.7\baselineskip}
  {\scriptsize\bfseries Academic Implications\par}
  {\scriptsize
  \begin{itemize}
    \item Grades of D, I, F, AB, DR, or NG are considered deficiencies in a student's academic status at the university.
    \item A grade of D is unsatisfactory. A student must re-enroll in the course within the next two consecutive semesters and earn a grade of C or better to earn course credits where university policy requires it.
    \item A grade of I indicates that a student completed a substantial part of the course with satisfactory performance but could not complete all requirements.
    \item A grade of F represents failure. The student must re-enroll in the course and earn a grade of C or better to earn course credits.
    \item A grade of AB indicates that the student did not take the final examination and provided documented evidence for that inability.
    \item A grade of DR indicates that the student exceeded the three excused absences allowed and must re-enroll to earn course credits.
    \item A grade of NG indicates that the student registered for the course but failed to officially withdraw or attend classes.
    \item A grade of W indicates an official withdrawal approved through the Office of the Registrar after consultation with the instructor and department chair and/or dean.
  \end{itemize}
  }
  \vspace{0.3\baselineskip}
  \fbox{\begin{minipage}{0.96\textwidth}\scriptsize \TUTranscriptMentionRulesNote\end{minipage}}
}

\newcommand{\TUPrintTranscript}{%
  \TUPrintTranscriptSummary
  \TUPrintTranscriptDetails
  \TUPrintTranscriptConclusion
  \TUPrintTranscriptBackMatter
}

